{
  "entities": {
    "student": {
      "title": "Student",
      "description": "Student information, attendance, exam results, and payments.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "gradeLevel": { "type": "string" },
        "track": { "type": "string" },
        "phone": { "type": "string" },
        "parentPhone": { "type": "string" },
        "school": { "type": "string" },
        "payments": { "type": "object" },
        "attendance": { "type": "object" },
        "examResults": { "type": "object" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "gradeLevel", "track", "phone", "parentPhone"]
    },
    "exam": {
      "title": "Exam",
      "description": "Exam detail and scoring limits.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string" },
        "maxScore": { "type": "number" },
        "gradeLevel": { "type": "string" }
      },
      "required": ["id", "title", "date", "maxScore", "gradeLevel"]
    },
    "admins": {
      "title": "AdminConfig",
      "description": "Collection containing secure username and password to log in to the administrator panel.",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "password": { "type": "string" }
      },
      "required": ["username", "password"]
    }
  },
  "firestore": {
    "students/{studentId}": {
      "schema": "student",
      "description": "Collection of student documents."
    },
    "exams/{examId}": {
      "schema": "exam",
      "description": "Collection of exam documents."
    },
    "admins/{adminId}": {
      "schema": "admins",
      "description": "Collection of admin configuration documents."
    }
  }
}
